# =============================================================================
# Beer Passport — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# =============================================================================

# ── Supabase (required) ───────────────────────────────────────────────────────
# Found in: Supabase dashboard → Settings → API

# Your project URL (e.g. https://xyzabc.supabase.co)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Public anon key — safe to expose in the browser
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here


# ── Edge Function environment (set these in Supabase dashboard → Edge Functions → Secrets)
# These are NOT Vite env vars — they live server-side only.

# Service role key — NEVER expose this in the browser
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Full URL of your deployed site (used to build the check-in QR link)
# SITE_URL=https://invasivespeciesbrewing.com/Invasive-Species
