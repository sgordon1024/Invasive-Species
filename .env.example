# =============================================================================
# Beer Passport — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# =============================================================================

# ── Beer Menu (optional) ─────────────────────────────────────────────────────
# Google Sheet published as CSV. If set, the live menu will be fetched from
# this URL on page load. If not set, the hardcoded menu in ScrollStop.jsx is used.
# How to get this URL: File → Share → Publish to web → CSV → Copy link
# VITE_MENU_SHEET_URL=https://docs.google.com/spreadsheets/d/YOUR_SHEET_ID/export?format=csv&gid=0

# ── Email Signup (optional) ───────────────────────────────────────────────────
# Google Apps Script web app URL for collecting email signups.
# When Mailchimp access is available, replace with the Mailchimp API endpoint.
# VITE_EMAIL_ENDPOINT=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec


# ── Supabase (required) ───────────────────────────────────────────────────────
# Found in: Supabase dashboard → Settings → API

# Your project URL (e.g. https://xyzabc.supabase.co)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Public anon key — safe to expose in the browser
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here


# ── Edge Function environment (set these in Supabase dashboard → Edge Functions → Secrets)
# These are NOT Vite env vars — they live server-side only.

# Service role key — NEVER expose this in the browser
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Full URL of your deployed site (used to build the check-in QR link)
# SITE_URL=https://invasivespeciesbrewing.com/Invasive-Species
