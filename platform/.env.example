# Invasive Ops — environment variables
# Copy to .env.local and fill in. Never commit .env.local.
#
# These can be the SAME Supabase project the public site uses, or a brand-new
# project dedicated to the platform. Found in: Supabase dashboard → Settings → API
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_publishable_anon_key_here
